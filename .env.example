# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Public site origin (used for canonical URLs / absolute links)
NEXT_PUBLIC_SITE_URL=https://www.leasing.co.il

# WhatsApp business number in international format, digits only (e.g. 972500000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000

# ── Marketing pixels (PUBLIC, client-side). ALL OPTIONAL — leave blank and the
# tags never load (the live funnel is unchanged). Set an id in Vercel and that
# channel lights up on the next deploy. Consent Mode v2 defaults to "denied"
# until the visitor accepts the consent banner. ──
# Google Analytics 4 — measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=
# Google Ads — conversion account id, e.g. AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Google Ads conversion labels (the part after "AW-XXXX/") for each funnel action
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_WHATSAPP_LABEL=
# Meta (Facebook/Instagram) Pixel id
NEXT_PUBLIC_META_PIXEL_ID=

# ── U.M.M crypto vault (SERVER-SIDE ONLY — never NEXT_PUBLIC_, never commit real values) ──
# Consumed only by lib/umm-crypto.ts (guarded by `server-only`). Used to authenticate
# supplier ("A2A") agents before any Big Five offer is trusted. The deal SCORE itself is
# sealed in leasing-api; these secrets only verify WHO may submit an offer.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
UMM_HMAC_SECRET=YOUR-GENERATED-HMAC-SECRET
NEXT_PRIVATE_A2A_AGENT_TOKEN=TOKEN-FOR-SUPPLIER-AGENTS

# ── Anthropic · U.M.M brain (server-side ONLY — never expose to the client) ──
# Used by app/api/brain + brain/*. Set the real value in:
#   • Vercel → Settings → Environment Variables (Production + Preview), then redeploy
#   • locally in .env.local (git-ignored)
# Never commit the real key, and never prefix it with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides — sensible defaults already live in brain/config.ts:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# BRAIN_MODEL_ULTRA=claude-sonnet-4-6
# BRAIN_MODEL_MASTER=claude-sonnet-4-6
# BRAIN_MODEL_MAX=claude-haiku-4-5-20251001

# ── U.M.M central brain (leasing-api) — SERVER-SIDE ONLY, never NEXT_PUBLIC_ ──
# MiaMe talks to the central brain as the `miame` tenant via lib/brain.ts +
# app/api/{deal,signal,catalog}. Tenant is resolved by the brain from the
# forwarded Host (never a client-asserted id). Leave LEASING_API_URL empty to run
# fully standalone (the storefront falls back to WhatsApp + Supabase only).
LEASING_API_URL=
# Host the brain maps to the miame tenant (matches tenants.domain in the brain):
MIAME_TENANT_HOST=miame.co.il
# Optional write-tier key (from `npm run seed:miame` in leasing-api); shown once:
MIAME_TENANT_API_KEY=
# LEASING_API_TIMEOUT_MS=4000

# ── Public API guards (M1) — SERVER-SIDE ONLY ──
# Origin allowlist for browser-initiated POSTs to /api/* (comma-separated).
# Empty = the owned domains (miame.co.il + leasing.co.il, apex+www); an Origin
# matching the request's own Host (production/preview) always passes.
ALLOWED_ORIGINS=
# Per-IP per-minute ceilings for each public POST route (0 disables that bucket):
# RATE_LIMIT_LEAD_MAX=5
# RATE_LIMIT_BRAIN_MAX=10
# RATE_LIMIT_DEAL_MAX=10
# RATE_LIMIT_SIGNAL_MAX=60
# RATE_LIMIT_MATCH_MAX=30
# RATE_LIMIT_MEDIA_EVENTS_MAX=60
# Admin gate for /api/embed (paid Voyage backfill + service-role write).
# UNSET = the route is disabled (fails closed). Set a long random value in
# Vercel only; callers must send it as the x-admin-token header.
EMBED_ADMIN_TOKEN=
