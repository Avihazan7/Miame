# MiaMe · environment (set in Vercel project settings for production)
# Lead persistence is OPTIONAL. Without these, /api/lead is a graceful no-op and the
# WhatsApp funnel still works end to end.

# Supabase (server-side only · NEVER expose the service role key to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp business number for CTAs (digits only, intl format, no +). Example: 972541234567
# Injected to the client via a small inline override or build replace of window.MIAME_WHATSAPP.
MIAME_WHATSAPP=
